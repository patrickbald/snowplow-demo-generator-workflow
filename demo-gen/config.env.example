# Project configuration — shared across the team, safe to commit
# Copy this file to config.env and fill in the values for your environment
# config.env is gitignored so you can store real values without committing them

# Snowplow Iglu registry URL (the shared private registry for this project)
SNOWPLOW_IGLU_REGISTRY_URL=

# Snowflake — project-level settings (not personal credentials)
SNOWFLAKE_DATABASE=     # e.g. ANALYTICS_DEV_DB
SNOWFLAKE_WAREHOUSE=    # e.g. ANALYTICS_DEV_WH
SNOWFLAKE_SCHEMA=       # e.g. yourname_dbt_demo  (use a personal schema to avoid conflicts)
SNOWFLAKE_ROLE=         # e.g. ANALYTICS_DEV_ROLE
