# Personal credentials — copy this file to .env and fill in your values
# .env is gitignored and should never be committed

# Absolute path to the repo root (no trailing slash)
REPO_ROOT=/path/to/dev-env-workflow

ANTHROPIC_API_KEY=sk-ant-...

# Snowplow BDP Console — find these at console.snowplowanalytics.com under API Keys
SNOWPLOW_CONSOLE_API_KEY_ID=
SNOWPLOW_CONSOLE_API_KEY=
SNOWPLOW_CONSOLE_ORG_ID=

# Snowplow Iglu — personal write key for publishing schemas
SNOWPLOW_IGLU_API_KEY=

# Snowflake — your personal account credentials
SNOWFLAKE_ACCOUNT=           # e.g. abc12345.eu-west-1
SNOWFLAKE_USER=              # e.g. your.name@snowplowanalytics.com
SNOWFLAKE_TOKEN=             # preferred: programmatic access token (create in Snowflake UI → Profile → Programmatic Access Tokens)
# SNOWFLAKE_PASSWORD=        # fallback if not using a token
